{
  "name": "Book & Brew Chatbot",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "pergunta",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "0e379980-71b5-4a5c-9236-966a22656849",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "webhookId": "pergunta"
    },
    {
      "parameters": {
        "jsCode": "const pergunta = $input.first().json.body.pergunta;\nconst contextos = $input.first().json.body.contexto || [];\n\nlet contextoFormatado = '';\nif (contextos.length > 0) {\n  contextoFormatado = '\\n\\n--- CONTEXTO DO BOOK & BREW ---\\n' +\n    contextos.map((c, i) => `[${i + 1}] ${c}`).join('\\n') +\n    '\\n--- FIM DO CONTEXTO ---';\n}\n\nconst systemPrompt = `Você é o assistente virtual do Book & Brew, uma cafeteria e livraria pet-friendly.\\n\\nRegras:\\n- Seja simpático, acolhedor e use emojis com moderação (🐾☕📚)\\n- Responda SOMENTE com base no contexto fornecido abaixo\\n- Se a pergunta não estiver no contexto, diga que não tem essa informação e sugira chamar o garçom\\n- Nunca invente preços ou informações que não estejam no contexto\\n- Responda em português brasileiro\\n- Seja conciso (máximo 3 parágrafos)${contextoFormatado}`;\n\nreturn [{\n  json: {\n    pergunta: pergunta,\n    systemPrompt: systemPrompt\n  }\n}];"
      },
      "id": "00981b18-382d-4307-839f-d7874eec9148",
      "name": "Formatar Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const resposta = $input.first().json.candidates[0].content.parts[0].text;\n\nreturn [{\n  json: {\n    resposta: resposta\n  }\n}];"
      },
      "id": "690ffa76-3939-4ade-ba5b-824531c5be67",
      "name": "Extrair Resposta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        0
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "a10f04fd-11c8-45f6-af8b-041420a13325",
      "name": "Responder Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        960,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "key",
              "value": ""
            }
          ]
        },
        "sendBody": true,
