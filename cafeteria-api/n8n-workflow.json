        "jsonBody": "={{ {\n  contents: [\n    {\n      parts: [\n        { text: $json.systemPrompt + \"\\n\\nPergunta: \" + $json.pergunta }\n      ]\n    }\n  ]\n} }}",
        "options": {
          "timeout": 120000
